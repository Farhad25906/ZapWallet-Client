# ============================================
# ZapWallet Client Environment Configuration
# ============================================
#
# VITE ENVIRONMENT VARIABLES
# - All Vite env variables must be prefixed with VITE_
# - These variables are embedded in the client-side code
# - DO NOT store secrets here (they will be exposed to users)
#
# ============================================

# ============================================
# API CONFIGURATION
# ============================================

# Backend API Base URL
# Type: Public
# Development: http://localhost:5000/api/v1
# Production: https://api.zapwallet.com/api/v1
VITE_BASE_URL=http://localhost:5000/api/v1

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# Application Name (displayed in browser tab, etc.)
# VITE_APP_NAME=ZapWallet

# Application Version
# VITE_APP_VERSION=1.0.0

# Enable Debug Mode (shows console logs in development)
# VITE_DEBUG=true

# Google Analytics Tracking ID (if using analytics)
# VITE_GA_TRACKING_ID=UA-XXXXXXXXX-X

# Sentry DSN (if using error tracking)
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ============================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================
#
# Before deploying to production:
# 1. Update VITE_BASE_URL to production API endpoint
# 2. Ensure API endpoint uses HTTPS
# 3. Remove or disable VITE_DEBUG
# 4. Build the application: npm run build
# 5. Test the production build: npm run preview
#
# ============================================
